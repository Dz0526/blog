---
import { PortableText } from "emdash/ui";
import type { PortableTextBlock } from "emdash";

interface Props {
  bio: PortableTextBlock[];
}

const { bio } = Astro.props;
---

<section class="about">
  <div class="about-inner">
    <h2 class="about-heading">About</h2>
    <div class="about-body">
      <PortableText value={bio} />
    </div>
  </div>
</section>

<style>
  .about {
    padding: var(--spacing-12, 3rem) var(--spacing-6, 1.5rem);
    border-bottom: 1px solid var(--color-border-subtle, #f0f0f0);
  }

  .about-inner {
    max-width: var(--max-width, 720px);
    margin: 0 auto;
  }

  .about-heading {
    font-size: var(--font-size-sm, 0.875rem);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider, 0.08em);
    color: var(--color-muted, #8b8b8b);
    margin: 0 0 var(--spacing-6, 1.5rem);
  }

  .about-body {
    font-size: var(--font-size-lg, 1.125rem);
    line-height: var(--leading-relaxed, 1.7);
    color: var(--color-text-secondary, #525252);
  }

  .about-body :global(p) {
    margin: 0 0 var(--spacing-4, 1rem);
  }

  .about-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .about-body :global(h2) {
    font-size: var(--font-size-xl, 1.25rem);
    font-weight: 600;
    color: var(--color-text, #1a1a1a);
    margin: var(--spacing-6, 1.5rem) 0 var(--spacing-3, 0.75rem);
  }

  .about-body :global(h3) {
    font-size: var(--font-size-lg, 1.125rem);
    font-weight: 600;
    color: var(--color-text, #1a1a1a);
    margin: var(--spacing-6, 1.5rem) 0 var(--spacing-3, 0.75rem);
  }

  .about-body :global(strong) {
    font-weight: 600;
    color: var(--color-text, #1a1a1a);
  }

  .about-body :global(em) {
    font-style: italic;
  }

  .about-body :global(ul),
  .about-body :global(ol) {
    padding-left: var(--spacing-6, 1.5rem);
    margin: 0 0 var(--spacing-4, 1rem);
  }

  .about-body :global(li) {
    margin-bottom: var(--spacing-2, 0.5rem);
  }

  @media (max-width: 600px) {
    .about {
      padding: var(--spacing-8, 2rem) var(--spacing-4, 1rem);
    }
  }
</style>
