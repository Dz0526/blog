---
interface ContactLink {
  label: string;
  url: string;
  icon: string;
}

interface Props {
  links: ContactLink[];
}

const { links } = Astro.props;

// Simple icon map for common contact icons
const iconSvg: Record<string, string> = {
  github: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`,
  email: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  twitter: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  linkedin: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  rss: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>`,
};

function getIcon(icon: string): string {
  return iconSvg[icon.toLowerCase()] ?? "";
}
---

<section class="contact">
  <div class="contact-inner">
    <h2 class="contact-heading">Contact</h2>
    {links.length > 0 ? (
      <ul class="contact-links" role="list">
        {links.map(({ label, url, icon }) => (
          <li>
            <a href={url} class="contact-link" rel="noopener noreferrer" target={url.startsWith("mailto:") ? undefined : "_blank"}>
              {getIcon(icon) ? <Fragment set:html={getIcon(icon)} /> : null}
              <span>{label}</span>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="contact-empty">連絡先はまだ登録されていません。</p>
    )}
  </div>
</section>

<style>
  .contact {
    padding: var(--spacing-12, 3rem) var(--spacing-6, 1.5rem);
  }

  .contact-inner {
    max-width: var(--max-width, 720px);
    margin: 0 auto;
  }

  .contact-heading {
    font-size: var(--font-size-sm, 0.875rem);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider, 0.08em);
    color: var(--color-muted, #8b8b8b);
    margin: 0 0 var(--spacing-6, 1.5rem);
  }

  .contact-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-3, 0.75rem);
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-2, 0.5rem);
    padding: var(--spacing-2, 0.5rem) var(--spacing-4, 1rem);
    background: var(--color-surface, #f7f7f7);
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: var(--radius, 4px);
    font-size: var(--font-size-sm, 0.875rem);
    font-weight: 500;
    color: var(--color-text-secondary, #525252);
    text-decoration: none;
    transition:
      color var(--transition-fast, 120ms ease),
      background var(--transition-fast, 120ms ease),
      border-color var(--transition-fast, 120ms ease);
  }

  .contact-link:hover {
    color: var(--color-accent, #0066cc);
    background: var(--color-bg, #ffffff);
    border-color: var(--color-accent, #0066cc);
  }

  .contact-link svg {
    flex-shrink: 0;
  }

  .contact-empty {
    font-size: var(--font-size-sm, 0.875rem);
    color: var(--color-muted, #8b8b8b);
    margin: 0;
  }

  @media (max-width: 600px) {
    .contact {
      padding: var(--spacing-8, 2rem) var(--spacing-4, 1rem);
    }
  }
</style>
